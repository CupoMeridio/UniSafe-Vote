
# File di progetto/workpackage
*.txt

# Dati sensibili e generati
data/keys/*
!data/keys/.gitkeep
data/receipts/*.json
data/voters.json
data/bulletin_board.json
data/ae_state.json
data/pins.json
data/tls/

# Report dei test di sicurezza (artefatti locali, generati a runtime)
# e CSV di Locust — tutta la cartella tests/output/ è esclusa
tests/output/*
!tests/output/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo

# Ambiente virtuale
venv/
env/
.venv/

# LaTeX build outputs
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.dvi
*.xdv
*.lof
*.lot
*.nav
*.snm
*.vrb
# Ignora tutto il contenuto di docs tranne il PDF del report principale
docs/*
!docs/main.pdf
build/

# OS
.DS_Store
Thumbs.db

# Altro
.env
*.db
.vscode/
.idea/
